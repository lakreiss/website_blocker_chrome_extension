{
  "manifest_version": 3,
  "name": "Ad-free Website Blocker",
  "description": "A simple browser extension to help keep yourself from visiting websites that distract you.",
  "version": "0.1.1",
  "version_name": "0.1.1 Pilot Launch with logo",
  "icons": {
    "128": "img/logo/128x128.png"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Click to manage blocked sites"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
